{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Values Schema",
  "type": "object",
  "properties": {
    "config": {
      "type": "object",
      "properties": {
        "cacheS3Bucket": {
          "type": "string",
          "minLength": 1,
          "description": "S3 bucket name for caching optimized images"
        },
        "allowedUpstreamGateways": {
          "type": "string",
          "minLength": 1,
          "description": "Comma-separated list of allowed upstream gateway domains"
        },
        "allowedSourceBuckets": {
          "type": "string",
          "minLength": 1,
          "description": "Comma-separated list of allowed source S3 buckets"
        }
      },
      "required": ["cacheS3Bucket", "allowedUpstreamGateways", "allowedSourceBuckets"]
    },
    "originVerify": {
      "type": "object",
      "properties": {
        "secretName": {
          "type": "string"
        }
      }
    }
  },
  "required": ["config"]
}
